@{
    ViewBag.Title = "Dashboard - CRM";
    Layout = "~/Views/Shared/_Layout.cshtml";
    int rolId = Session["RolId"] != null ? (int)Session["RolId"] : 2;
    bool isAdmin = rolId == 1;

    var chartFechas = (string[])ViewBag.EventosFechas;
    var chartCantidades = (int[])ViewBag.EventosCantidades;
}

<div class="box-body px-0 content-header d-lg-flex d-sm-block align-items-center justify-content-between">
    <h1>
        Dashboard CRM
        <small>@(isAdmin ? "Panel de Administrador" : "Panel de Empleado")</small>
    </h1>
    <div class="d-flex align-items-center">
        <!-- Filtro global dinámico de tiempo -->
        <div class="me-3">
            <select id="filtro-global" class="form-select border-primary fw-bold" style="width: 220px;">
                <option value="todos" @(ViewBag.FiltroActivo == "todos" ? "selected" : "")>⏰ Todos los tiempos</option>
                <option value="dia" @(ViewBag.FiltroActivo == "dia" ? "selected" : "")>📅 Hoy</option>
                <option value="semana" @(ViewBag.FiltroActivo == "semana" ? "selected" : "")>🗓️ Última Semana</option>
                <option value="mes" @(ViewBag.FiltroActivo == "mes" ? "selected" : "")>📊 Último Mes</option>
                <option value="anio" @(ViewBag.FiltroActivo == "anio" ? "selected" : "")>📈 Último Año</option>
            </select>
        </div>

        <div class="me-3">
            <a href="@Url.Action("ExportarClientesCSV", "Clientes")" class="btn btn-success d-flex align-items-center" style="background-color: #10c469; border-color: #10c469; color: white; font-weight: 500;">
                <i class="fa fa-file-excel me-2"></i> Exportar Clientes
            </a>
        </div>
        <ol class="breadcrumb p-0 m-0">
            <li class="breadcrumb-item"><a href="~/Dashboard"><i class="fa fa-dashboard"></i> Inicio</a></li>
            <li class="breadcrumb-item active">Dashboard</li>
        </ol>
    </div>
</div>

<!-- Tarjetas de Métricas -->
<div class="row first-section">
    <div class="col-xxl-3 col-xl-6 col-12">
        <div class="box pull-up bg-primary">
            <div class="box-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="me-15 text-center">
                        <i class="si-people si fs-40"></i>
                    </div>
                    <div class="d-flex flex-column text-end">
                        <h2 class="fs-30 mb-1 mt-0">@ViewBag.TotalClientes</h2>
                        <p class="m-0">Clientes @(isAdmin ? "Totales" : "Asignados")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xxl-3 col-xl-6 col-12">
        <div class="box pull-up bg-success">
            <div class="box-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="me-15 text-center">
                        <i class="ti-bag fs-40"></i>
                    </div>
                    <div class="d-flex flex-column text-end">
                        <h2 class="fs-30 mb-1 mt-0">@ViewBag.TotalOportunidades</h2>
                        <p class="m-0">Oportunidades @(isAdmin ? "Activas" : "Mías")</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xxl-3 col-xl-6 col-12">
        <div class="box pull-up bg-warning">
            <div class="box-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="me-15 text-center">
                        <i class="ti-check-box fs-40"></i>
                    </div>
                    <div class="d-flex flex-column text-end">
                        <h2 class="fs-30 mb-1 mt-0">@ViewBag.TotalTareas</h2>
                        <p class="m-0">Tareas Pendientes</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xxl-3 col-xl-6 col-12">
        <div class="box pull-up bg-danger">
            <div class="box-body">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="me-15 text-center">
                        <i class="ti-bar-chart fs-40"></i>
                    </div>
                    <div class="d-flex flex-column text-end">
                        <h2 class="fs-30 mb-1 mt-0">@ViewBag.TotalUsuarios</h2>
                        <p class="m-0">Usuarios en Sistema</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Gráficos de Eventos / Citas (HU-025) -->
<div class="row">
    <div class="col-xxl-8 col-xl-8 col-lg-12 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Cantidad de Citas Agendadas</h4>
            </div>
            <div class="box-body">
                <div id="eventos-line-chart" class="chart-responsive"></div>
            </div>
        </div>
    </div>

    <div class="col-xxl-4 col-xl-4 col-lg-12 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Proporción por Estados de Citas</h4>
            </div>
            <div class="box-body">
                <div id="estados-donut-chart" class="chart-responsive"></div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Lista de Tareas Próximas -->
    <div class="col-xxl-6 col-xl-6 col-lg-12 col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h4 class="box-title">@(isAdmin ? "Todas las Tareas Pendientes" : "Mis Tareas Pendientes")</h4>
                <a href="~/Tareas" class="btn btn-sm btn-primary-light">Ver todo</a>
            </div>
            <div class="box-body p-0">
                <div class="media-list media-list-hover media-list-divided">
                    @if (((List<CRMRSG.EntityFramework.tarea>)ViewBag.TareasProximas).Count == 0)
                    {
                        <div class="p-20 text-center text-muted">No hay tareas pendientes para este período.</div>
                    }
                    @foreach (var t in (List<CRMRSG.EntityFramework.tarea>)ViewBag.TareasProximas)
                    {
                        <a class="media media-single" href="~/Tareas">
                            <div class="me-10 d-flex align-items-center">
                                <i class="fa fa-circle text-@(t.prioridad == "Alta" ? "danger" : (t.prioridad == "Media" ? "warning" : "info")) fs-10"></i>
                            </div>
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-bold">@t.titulo</h6>
                                <small class="text-fade">Vence: @(t.fecha_limite.HasValue ? t.fecha_limite.Value.ToString("dd/MM/yyyy") : "Sin fecha")</small>
                            </div>
                            <span class="badge badge-@(t.prioridad == "Alta" ? "danger" : (t.prioridad == "Media" ? "warning" : "info"))-light">@t.prioridad</span>
                        </a>
                    }
                </div>
            </div>
        </div>
    </div>

    <!-- Lista de Actividades Recientes (Bitácora) -->
    <div class="col-xxl-6 col-xl-6 col-lg-12 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">Últimas Acciones en el Sistema</h4>
            </div>
            <div class="box-body p-0">
                <div class="media-list media-list-hover media-list-divided">
                    @if (((List<CRMRSG.EntityFramework.bitacora>)ViewBag.ActividadesRecientes).Count == 0)
                    {
                        <div class="p-20 text-center text-muted">No se registran actividades recientes.</div>
                    }
                    @foreach (var act in (List<CRMRSG.EntityFramework.bitacora>)ViewBag.ActividadesRecientes)
                    {
                        <div class="media media-single">
                            <div class="flex-grow-1">
                                <h6 class="mb-0 fw-bold">@act.accion en @act.tabla_afectada</h6>
                                <p class="text-muted fs-12 mb-0">Realizado por: @(act.usuario != null ? act.usuario.nombre + " " + act.usuario.apellido : "Sistema")</p>
                            </div>
                            <span class="badge badge-primary-light">
                                @(act.fecha_hora.HasValue ? act.fecha_hora.Value.ToString("HH:mm") : "")
                            </span>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Ganancias por Cliente (Oportunidades Ganadas)</h4>
            </div>
            <div class="box-body">
                <div id="ganancias-bar-chart" style="min-height: 350px;"></div>
            </div>
        </div>
    </div>
</div>

<!-- Rendimiento de Vendedores (HU-035) - Solo visible para Administradores -->
@if (isAdmin)
{
    <div class="row">
        <div class="col-12">
            <div class="box">
                <div class="box-header with-border">
                    <h4 class="box-title">Rendimiento y Productividad de Vendedores</h4>
                </div>
                <div class="box-body">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th>Colaborador / Vendedor</th>
                                    <th class="text-center">Clientes Asignados</th>
                                    <th class="text-center">Oportunidades Registradas</th>
                                    <th class="text-center">Tareas Asignadas</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in (IEnumerable<CRMRSG.Controllers.VendedorRendimiento>)ViewBag.Vendedores)
                                {
                                    <tr>
                                        <td class="fw-bold">@item.Nombre</td>
                                        <td class="text-center">@item.Clientes</td>
                                        <td class="text-center">@item.Oportunidades</td>
                                        <td class="text-center">@item.Tareas</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@section scripts {
    <script src="~/Content/assets/vendor_components/apexcharts-bundle/dist/apexcharts.js"></script>

    <script>
        $(document).ready(function () {
            // Manejador del filtro global de tiempo
            $('#filtro-global').on('change', function() {
                window.location.href = '@Url.Action("Index", "Dashboard")?filtro=' + $(this).val();
            });

            // Gráfico de Citas por Fecha - ApexCharts
            if ($('#eventos-line-chart').length > 0) {
                var fechas = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(chartFechas));
                var cantidades = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(chartCantidades));

                var optionsLine = {
                    series: [{ name: 'Citas', data: cantidades }],
                    chart: { type: 'area', height: 300, toolbar: { show: false } },
                    stroke: { curve: 'smooth', width: 2 },
                    xaxis: { categories: fechas },
                    colors: ['#040A2D'],
                    fill: {
                        type: 'gradient',
                        gradient: {
                            shadeIntensity: 1,
                            opacityFrom: 0.3,
                            opacityTo: 0.05,
                            stops: [0, 90, 100]
                        }
                    },
                    dataLabels: { enabled: false }
                };
                new ApexCharts(document.querySelector("#eventos-line-chart"), optionsLine).render();
            }

            // Gráfico de Citas por Estado - Donut Chart
            if ($('#estados-donut-chart').length > 0) {
                var completados = @ViewBag.EventosCompletados;
                var pendientes = @ViewBag.EventosPendientes;
                var cancelados = @ViewBag.EventosCancelados;
                var aplazados = @(ViewBag.EventosAplazados ?? 0);

                var optionsDonut = {
                    series: [completados, pendientes, cancelados, aplazados],
                    chart: { type: 'donut', height: 300 },
                    labels: ['Completadas', 'Pendientes', 'Canceladas', 'Aplazadas'],
                    colors: ['#10c469', '#ff9920', '#ff5b5b', '#7367f0'], // Verde, Naranja, Rojo, Morado
                    legend: { position: 'bottom' },
                    stroke: { colors: ['#ffffff'], width: 2 }
                };
                new ApexCharts(document.querySelector("#estados-donut-chart"), optionsDonut).render();
            }

            // Gráfico de Ganancias por Cliente - Bar Chart
            if ($('#ganancias-bar-chart').length > 0) {
                var clientesGanancias = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GananciasLabels));
                var montosGanancias = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(ViewBag.GananciasData));

                var optionsBar = {
                    series: [{
                        name: 'Ganancias',
                        data: montosGanancias
                    }],
                    chart: {
                        type: 'bar',
                        height: 350,
                        toolbar: { show: false }
                    },
                    plotOptions: {
                        bar: {
                            borderRadius: 6,
                            horizontal: false,
                            columnWidth: '45%',
                            distributed: true
                        }
                    },
                    dataLabels: {
                        enabled: true,
                        formatter: function (val) {
                            return "$" + val.toLocaleString();
                        },
                        style: {
                            colors: ['#FFFFFF']
                        }
                    },
                    colors: ['#040A2D', '#970000', '#7a7a7a', '#c2c2c2', '#a8a8a8'],
                    xaxis: {
                        categories: clientesGanancias,
                        labels: {
                            style: {
                                colors: '#000000',
                                fontWeight: 500
                            }
                        }
                    },
                    yaxis: {
                        title: {
                            text: 'Monto ($)'
                        },
                        labels: {
                            formatter: function (val) {
                                return "$" + val.toLocaleString();
                            }
                        }
                    },
                    grid: {
                        borderColor: '#ededed'
                    },
                    legend: {
                        show: false
                    }
                };
                new ApexCharts(document.querySelector("#ganancias-bar-chart"), optionsBar).render();
            }
        });
    </script>
}