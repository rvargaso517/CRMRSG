@{
    ViewBag.Title = "Tareas por Prioridad";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Tareas por Prioridad</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="~/Dashboard">
                                <i class="mdi mdi-home-outline"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="~/Tareas">Tareas</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Prioridades
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">

    <div class="col-xl-4 col-md-4 col-12">
        <div class="box">
            <div class="box-body text-center">
                <h5 class="text-muted">Prioridad Alta</h5>
                <h2 class="fs-30 mb-1 mt-0">@ViewBag.Alta</h2>
                <span class="badge badge-danger">
                    Tareas Alta
                </span>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-4 col-12">
        <div class="box">
            <div class="box-body text-center">
                <h5 class="text-muted">Prioridad Media</h5>
                <h2 class="fs-30 mb-1 mt-0">@ViewBag.Media</h2>
                <span class="badge badge-warning">
                    Tareas Media
                </span>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-4 col-12">
        <div class="box">
            <div class="box-body text-center">
                <h5 class="text-muted">Prioridad Baja</h5>
                <h2 class="fs-30 mb-1 mt-0">@ViewBag.Baja</h2>
                <span class="badge badge-info">
                    Tareas Baja
                </span>
            </div>
        </div>
    </div>

</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">
                    Resumen de Prioridades
                </h4>
            </div>
            <div class="box-body">

                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Prioridad</th>
                            <th>Total de Tareas</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr>
                            <td>
                                <span class="badge badge-danger">
                                    Alta
                                </span>
                            </td>
                            <td>@ViewBag.Alta</td>
                        </tr>

                        <tr>
                            <td>
                                <span class="badge badge-warning">
                                    Media
                                </span>
                            </td>
                            <td>@ViewBag.Media</td>
                        </tr>

                        <tr>
                            <td>
                                <span class="badge badge-info">
                                    Baja
                                </span>
                            </td>
                            <td>@ViewBag.Baja</td>
                        </tr>
                    </tbody>

                </table>

            </div>
        </div>
    </div>
</div>