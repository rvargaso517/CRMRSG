@{
    ViewBag.Title = "Nueva Tarea";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Nueva Tarea</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item"><a href="~/Tareas">Tareas</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Crear</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">Detalles de la Tarea</h4>
            </div>
            <form class="form">
                <div class="box-body">
                    <div class="form-group">
                        <label class="form-label">Asunto</label>
                        <input type="text" class="form-control" placeholder="Ej: Llamar para confirmar reunión">
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Fecha de Vencimiento</label>
                                <input type="date" class="form-control">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Prioridad</label>
                                <select class="form-select">
                                    <option>Baja</option>
                                    <option selected>Media</option>
                                    <option>Alta</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Relacionado con</label>
                        <select class="form-select">
                            <option>Ninguno</option>
                            <optgroup label="Clientes">
                                <option>Acme Corporation</option>
                                <option>Tech Solutions</option>
                            </optgroup>
                            <optgroup label="Oportunidades">
                                <option>Venta Licencias Q3</option>
                                <option>Implementación ERP</option>
                            </optgroup>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Notas Adicionales</label>
                        <textarea rows="4" class="form-control" placeholder="Escribe aquí los detalles..."></textarea>
                    </div>
                </div>
                <div class="box-footer text-end">
                    <a href="~/Tareas" class="btn btn-warning me-1">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar Tarea</button>
                </div>
            </form>
        </div>
    </div>
</div>
