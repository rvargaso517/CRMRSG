@{
    ViewBag.Title = "Tareas por Categorías";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Tareas por Categorías</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="~/Dashboard">
                                <i class="mdi mdi-home-outline"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item">
                            <a href="~/Tareas">Tareas</a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Categorías
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">

    <div class="col-xl-4 col-md-4 col-12">
        <div class="box">
            <div class="box-body text-center">
                <h5 class="text-muted">Pendientes</h5>
                <h2 class="fs-30 mb-1 mt-0">@ViewBag.Pendientes</h2>
                <span class="badge badge-warning">
                    Pendientes
                </span>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-4 col-12">
        <div class="box">
            <div class="box-body text-center">
                <h5 class="text-muted">En Proceso</h5>
                <h2 class="fs-30 mb-1 mt-0">@ViewBag.EnProceso</h2>
                <span class="badge badge-info">
                    En Proceso
                </span>
            </div>
        </div>
    </div>

    <div class="col-xl-4 col-md-4 col-12">
        <div class="box">
            <div class="box-body text-center">
                <h5 class="text-muted">Completadas</h5>
                <h2 class="fs-30 mb-1 mt-0">@ViewBag.Completadas</h2>
                <span class="badge badge-success">
                    Completadas
                </span>
            </div>
        </div>
    </div>

</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">
                    Resumen de Categorías
                </h4>
            </div>

            <div class="box-body">
                <table class="table table-hover">

                    <thead>
                        <tr>
                            <th>Categoría</th>
                            <th>Total de Tareas</th>
                        </tr>
                    </thead>

                    <tbody>

                        <tr>
                            <td>
                                <span class="badge badge-warning">
                                    Pendientes
                                </span>
                            </td>
                            <td>@ViewBag.Pendientes</td>
                        </tr>

                        <tr>
                            <td>
                                <span class="badge badge-info">
                                    En Proceso
                                </span>
                            </td>
                            <td>@ViewBag.EnProceso</td>
                        </tr>

                        <tr>
                            <td>
                                <span class="badge badge-success">
                                    Completadas
                                </span>
                            </td>
                            <td>@ViewBag.Completadas</td>
                        </tr>

                    </tbody>

                </table>
            </div>
        </div>
    </div>
</div>