@model List<CRMRSG.EntityFramework.tarea>

@{
    ViewBag.Title = "Tareas";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var usuarios = (List<CRMRSG.EntityFramework.usuario>)ViewBag.Usuarios;
    var selectedId = (int?)ViewBag.SelectedUsuarioId;

    var userLabels = (string[])ViewBag.UserLabels;
    var userValues = (int[])ViewBag.UserValues;

    var categoryLabels = (string[])ViewBag.CategoryLabels;
    var categoryValues = (int[])ViewBag.CategoryValues;

    var priorityLabels = (string[])ViewBag.PriorityLabels;
    var priorityValues = (int[])ViewBag.PriorityValues;
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Gestión de Tareas</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="~/Dashboard">
                                <i class="mdi mdi-home-outline"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Tareas
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<!-- Filtros y Selección de Usuario -->
<div class="row">
    <div class="col-12 mb-20">
        <div class="box">
            <div class="box-body py-15">
                @using (Html.BeginForm("Index", "Tareas", FormMethod.Get, new { @class = "row align-items-end" }))
                {
                    <div class="col-md-9 col-12 form-group mb-0">
                        <label class="form-label">Filtrar Tareas por Propietario / Asignado</label>
                        <select name="usuarioId" class="form-select">
                            <option value="">-- Todos los Usuarios / Colaboradores --</option>
                            @foreach (var user in usuarios)
                            {
                                <option value="@user.id_usuario" @(selectedId == user.id_usuario ? "selected" : "")>
                                    @user.nombre @user.apellido (@user.correo)
                                </option>
                            }
                        </select>
                    </div>
                    <div class="col-md-3 col-12 text-end">
                        <button type="submit" class="btn btn-primary w-100">
                            <i class="fa fa-filter me-2"></i> Aplicar Filtro
                        </button>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<!-- Gráficos de Estadísticas -->
<div class="row">
    <!-- Tareas por Usuario -->
    <div class="col-xl-4 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Carga por Usuario</h4>
            </div>
            <div class="box-body">
                <div id="user-task-chart"></div>
            </div>
        </div>
    </div>
    <!-- Categoría de Tareas -->
    <div class="col-xl-4 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Tareas por Estado</h4>
            </div>
            <div class="box-body">
                <div id="category-task-chart"></div>
            </div>
        </div>
    </div>
    <!-- Tareas por Prioridad -->
    <div class="col-xl-4 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Distribución de Prioridades</h4>
            </div>
            <div class="box-body">
                <div id="priority-task-chart"></div>
            </div>
        </div>
    </div>
</div>

<!-- Listado de Tareas -->
<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Listado General de Tareas</h3>
                <a href="~/Tareas/Crear" class="btn btn-primary">
                    <i class="fa fa-plus"></i> Nueva Tarea
                </a>
            </div>

            <div class="box-body p-0">
                <div class="table-responsive">
                    @Html.AntiForgeryToken()
                    <table class="table table-hover mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Responsable</th>
                                <th>Descripción de la Tarea</th>
                                <th>Relacionado con</th>
                                <th>Vencimiento</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                                <th class="text-center">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model.Count == 0)
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted p-20">
                                        No se encontraron tareas registradas.
                                    </td>
                                </tr>
                            }
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold">
                                        @(item.usuario != null ? item.usuario.nombre + " " + item.usuario.apellido : "Sin asignar")
                                    </td>
                                    <td>
                                        <span class="text-dark fw-500">
                                            @item.titulo
                                        </span>
                                        @if (!string.IsNullOrEmpty(item.descripcion))
                                        {
                                            <br /><small class="text-fade">@item.descripcion</small>
                                        }
                                    </td>
                                    <td>
                                        @(item.cliente != null
                                            ? item.cliente.empresa
                                            : "Sin cliente")
                                    </td>
                                    <td>
                                        @(item.fecha_limite.HasValue
                                            ? item.fecha_limite.Value.ToString("dd/MM/yyyy")
                                            : "Sin fecha")
                                    </td>
                                    <td>
                                        @if (item.prioridad == "Alta")
                                        {
                                            <span class="badge badge-danger">Alta</span>
                                        }
                                        else if (item.prioridad == "Media")
                                        {
                                            <span class="badge badge-warning text-dark">Media</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">Baja</span>
                                        }
                                    </td>
                                    <td>
                                        @if (item.estado == "Completada")
                                        {
                                            <span class="badge badge-success-light">@item.estado</span>
                                        }
                                        else if (item.estado == "Aplazada")
                                        {
                                            <span class="badge badge-danger-light">@item.estado</span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning-light">@item.estado</span>
                                        }
                                    </td>
                                    <td class="text-center">
                                        @if (item.estado != "Completada")
                                        {
                                            <button class="btn btn-sm btn-success-light btn-completar-tarea" data-id="@item.id_tarea" title="Marcar como completada">
                                                <i class="fa fa-check"></i> Completada
                                            </button>
                                            <button class="btn btn-sm btn-warning-light btn-posponer-tarea" data-id="@item.id_tarea" title="Aplazar / Posponer">
                                                <i class="fa fa-clock-o"></i> Aplazar
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Modal Posponer Tarea -->
<div class="modal fade" id="modal-posponer-tarea" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Aplazar Tarea Comercial</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="form-group mb-3">
                    <label class="form-label">Nueva Fecha Límite</label>
                    <input type="date" id="posponer-fecha" class="form-control" required />
                </div>
                <div class="form-group mb-3">
                    <label class="form-label">Razón del Aplazamiento / Justificación</label>
                    <textarea id="posponer-razon" rows="3" class="form-control" placeholder="Escriba aquí la justificación de por qué se posterga la actividad comercial..." required></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-warning" id="btn-confirmar-posponer">Confirmar Aplazamiento</button>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script src="~/Content/assets/vendor_components/apexcharts-bundle/dist/apexcharts.js"></script>
    <script>
        $(document).ready(function() {
            // Completar Tarea AJAX
            $('.btn-completar-tarea').on('click', function() {
                var taskId = $(this).data('id');
                var token = $('input[name="__RequestVerificationToken"]').val();
                
                if (confirm('¿Desea marcar esta tarea como completada?')) {
                    $.ajax({
                        url: '@Url.Action("Completar", "Tareas")',
                        type: 'POST',
                        data: {
                            id: taskId,
                            __RequestVerificationToken: token
                        },
                        success: function(res) {
                            if (res.success) {
                                alert(res.message);
                                location.reload();
                            } else {
                                alert(res.message);
                            }
                        },
                        error: function() {
                            alert('Error de red al completar la tarea.');
                        }
                    });
                }
            });

            // Posponer Tarea AJAX
            var currentPosponerId = null;
            $('.btn-posponer-tarea').on('click', function() {
                currentPosponerId = $(this).data('id');
                $('#modal-posponer-tarea').modal('show');
            });

            $('#btn-confirmar-posponer').on('click', function() {
                var razon = $('#posponer-razon').val();
                var nuevaFecha = $('#posponer-fecha').val();
                var token = $('input[name="__RequestVerificationToken"]').val();

                if (!nuevaFecha || !razon) {
                    alert('Debe rellenar la nueva fecha y justificar el aplazamiento.');
                    return;
                }

                $.ajax({
                    url: '@Url.Action("Posponer", "Tareas")',
                    type: 'POST',
                    data: {
                        id: currentPosponerId,
                        razon: razon,
                        nuevaFecha: nuevaFecha,
                        __RequestVerificationToken: token
                    },
                    success: function(res) {
                        if (res.success) {
                            $('#modal-posponer-tarea').modal('hide');
                            alert(res.message);
                            location.reload();
                        } else {
                            alert(res.message);
                        }
                    },
                    error: function() {
                        alert('Error al postergar la tarea.');
                    }
                });
            });

            // Tareas por Usuario (Pie Chart)
            if($('#user-task-chart').length > 0) {
                var userLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(userLabels));
                var userValues = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(userValues));

                if (userLabels.length === 0) {
                    userLabels = ['Sin datos'];
                    userValues = [0];
                }

                var optionsUser = {
                    series: userValues,
                    chart: { type: 'pie', height: 280 },
                    labels: userLabels,
                    colors: ['#040A2D', '#970000', '#10c469', '#ff9920', '#188ae2'],
                    stroke: { colors: ['#ffffff'], width: 1 },
                    legend: { position: 'bottom' }
                };
                new ApexCharts(document.querySelector("#user-task-chart"), optionsUser).render();
            }

            // Tareas por Categoría/Estado (Donut Chart)
            if($('#category-task-chart').length > 0) {
                var catLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(categoryLabels));
                var catValues = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(categoryValues));

                if (catLabels.length === 0) {
                    catLabels = ['Sin datos'];
                    catValues = [0];
                }

                var optionsCategory = {
                    series: catValues,
                    chart: { type: 'donut', height: 280 },
                    labels: catLabels,
                    colors: ['#ff9920', '#188ae2', '#10c469'],
                    stroke: { colors: ['#ffffff'], width: 1 },
                    legend: { position: 'bottom' }
                };
                new ApexCharts(document.querySelector("#category-task-chart"), optionsCategory).render();
            }

            // Tareas por Prioridad (Bar Chart)
            if($('#priority-task-chart').length > 0) {
                var prioLabels = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(priorityLabels));
                var prioValues = @Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(priorityValues));

                if (prioLabels.length === 0) {
                    prioLabels = ['Alta', 'Media', 'Baja'];
                    prioValues = [0, 0, 0];
                }

                var optionsPriority = {
                    series: [{ name: 'Tareas', data: prioValues }],
                    chart: { type: 'bar', height: 280, toolbar: { show: false } },
                    plotOptions: { bar: { columnWidth: '40%', borderRadius: 4, distributed: true } },
                    xaxis: { categories: prioLabels },
                    colors: ['#970000', '#040A2D', '#9e9e9e'],
                    legend: { show: false },
                    dataLabels: { enabled: false }
                };
                new ApexCharts(document.querySelector("#priority-task-chart"), optionsPriority).render();
            }
        });
    </script>
}
