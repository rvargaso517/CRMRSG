@model List<CRMRSG.EntityFramework.tarea>

@{
    ViewBag.Title = "Mis Tareas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Tareas</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="~/Dashboard">
                                <i class="mdi mdi-home-outline"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Mis Tareas
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Lista de Tareas</h3>

                ```
                <a href="~/Tareas/Crear" class="btn btn-primary">
                    <i class="fa fa-plus"></i> Nueva Tarea
                </a>
            </div>

            <div class="box-body p-0">
                <div class="table-responsive">

                    <table class="table table-hover mb-0">

                        <thead class="bg-light">
                            <tr>
                                <th style="width: 50px;"></th>
                                <th>Descripción de la Tarea</th>
                                <th>Relacionado con</th>
                                <th>Vencimiento</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <div class="checkbox">
                                            <input type="checkbox"
                                                   id="task_@item.id_tarea">
                                            <label for="task_@item.id_tarea"></label>
                                        </div>
                                    </td>

                                    <td>
                                        <a href="#"
                                           class="text-dark fw-500 hover-primary">
                                            @item.titulo
                                        </a>
                                    </td>

                                    <td>
                                        @(item.cliente != null
                                        ? item.cliente.nombre
                                        : "Sin cliente")
                                    </td>

                                    <td>
                                        @(item.fecha_limite.HasValue
                                        ? item.fecha_limite.Value.ToString("dd/MM/yyyy")
                                        : "Sin fecha")
                                    </td>

                                    <td>

                                        @if (item.prioridad == "Alta")
                                        {
                                            <span class="badge badge-danger">
                                                Alta
                                            </span>
                                        }
                                        else if (item.prioridad == "Media")
                                        {
                                            <span class="badge badge-warning">
                                                Media
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">
                                                Baja
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (item.estado == "Completada")
                                        {
                                            <span class="badge badge-success-light">
                                                @item.estado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning-light">
                                                @item.estado
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            </div>
        </div>
    </div>
    ```

</div>
