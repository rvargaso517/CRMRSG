@model List<CRMRSG.EntityFramework.tarea>

@{
    ViewBag.Title = "Mis Tareas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Tareas</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="~/Dashboard">
                                <i class="mdi mdi-home-outline"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Mis Tareas
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <!-- Tareas por Usuario -->
    <div class="col-xl-4 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Filtro por Usuario</h4>
            </div>
            <div class="box-body">
                <div id="user-task-chart"></div>
            </div>
        </div>
    </div>
    <!-- Categor&iacute;a de Tareas -->
    <div class="col-xl-4 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Tareas por Categor&iacute;a</h4>
            </div>
            <div class="box-body">
                <div id="category-task-chart"></div>
            </div>
        </div>
    </div>
    <!-- Tareas por Prioridad -->
    <div class="col-xl-4 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title" style="color: #040A2D;">Tareas con Prioridad</h4>
            </div>
            <div class="box-body">
                <div id="priority-task-chart"></div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Lista de Tareas</h3>

                ```
                <a href="~/Tareas/Crear" class="btn btn-primary">
                    <i class="fa fa-plus"></i> Nueva Tarea
                </a>
            </div>

            <div class="box-body p-0">
                <div class="table-responsive">

                    <table class="table table-hover mb-0">

                        <thead class="bg-light">
                            <tr>
                                <th class="w-25"></th>
                                <th>Descripci&oacute;n de la Tarea</th>
                                <th>Relacionado con</th>
                                <th>Vencimiento</th>
                                <th>Prioridad</th>
                                <th>Estado</th>
                            </tr>
                        </thead>

                        <tbody>

                            @foreach (var item in Model)
                            {
                                <tr>

                                    <td>
                                        <div class="checkbox">
                                            <input type="checkbox"
                                                   id="task_@item.id_tarea">
                                            <label for="task_@item.id_tarea"></label>
                                        </div>
                                    </td>

                                    <td>
                                        <a href="#"
                                           class="text-dark fw-500 hover-primary">
                                            @item.titulo
                                        </a>
                                    </td>

                                    <td>
                                        @(item.cliente != null
                                        ? item.cliente.nombre
                                        : "Sin cliente")
                                    </td>

                                    <td>
                                        @(item.fecha_limite.HasValue
                                        ? item.fecha_limite.Value.ToString("dd/MM/yyyy")
                                        : "Sin fecha")
                                    </td>

                                    <td>

                                        @if (item.prioridad == "Alta")
                                        {
                                            <span class="badge badge-danger">
                                                Alta
                                            </span>
                                        }
                                        else if (item.prioridad == "Media")
                                        {
                                            <span class="badge badge-warning">
                                                Media
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-info">
                                                Baja
                                            </span>
                                        }

                                    </td>

                                    <td>

                                        @if (item.estado == "Completada")
                                        {
                                            <span class="badge badge-success-light">
                                                @item.estado
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge badge-warning-light">
                                                @item.estado
                                            </span>
                                        }

                                    </td>

                                </tr>
                            }

                        </tbody>

                    </table>

                </div>
            </div>
        </div>
    </div>
    ```

</div>

@section scripts {
    <script src="~/Content/assets/vendor_components/apexcharts-bundle/dist/apexcharts.js"></script>
    <script>
        $(document).ready(function() {
            // Tareas por Usuario (Pie Chart)
            if($('#user-task-chart').length > 0) {
                var optionsUser = {
                    series: [12, 8, 5],
                    chart: { type: 'pie', height: 300 },
                    labels: ['Juan Garc&iacute;a', 'Ana Mart&iacute;nez', 'Carlos L&oacute;pez'],
                    colors: ['#040A2D', '#970000', '#ededed'], // Azul, Rojo, Gris
                    stroke: { colors: ['#000000'], width: 1 },
                    legend: { position: 'bottom' }
                };
                new ApexCharts(document.querySelector("#user-task-chart"), optionsUser).render();
            }

            // Tareas por Categor&iacute;a (Donut Chart)
            if($('#category-task-chart').length > 0) {
                var optionsCategory = {
                    series: [15, 6, 4],
                    chart: { type: 'donut', height: 300 },
                    labels: ['Correos', 'Cotizaciones', 'Reuniones'],
                    colors: ['#040A2D', '#970000', '#ededed'], // Azul, Rojo, Gris
                    stroke: { colors: ['#000000'], width: 1 },
                    legend: { position: 'bottom' }
                };
                new ApexCharts(document.querySelector("#category-task-chart"), optionsCategory).render();
            }

            // Tareas por Prioridad (Bar Chart Moderno)
            if($('#priority-task-chart').length > 0) {
                var optionsPriority = {
                    series: [{ name: 'Tareas', data: [80, 55, 35] }],
                    chart: { type: 'bar', height: 300, toolbar: { show: false } },
                    plotOptions: { bar: { columnWidth: '35%', borderRadius: 4, distributed: true } },
                    xaxis: { categories: ['Alta', 'Media', 'Baja'] },
                    colors: ['#970000', '#040A2D', '#9e9e9e'], // Rojo, Azul, Gris
                    fill: { type: 'gradient', gradient: { shade: 'light', type: 'vertical', shadeIntensity: 0.25, inverseColors: false, opacityFrom: 1, opacityTo: 0.7, stops: [50, 100] } },
                    legend: { show: false },
                    dataLabels: { enabled: false }
                };
                new ApexCharts(document.querySelector("#priority-task-chart"), optionsPriority).render();
            }
        });
    </script>
}





