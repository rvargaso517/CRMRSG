@{
    ViewBag.Title = "Actividades";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Actividades</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item active" aria-current="page">Registro de Actividades</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Historial de Actividades</h3>
                <a href="~/Actividades/Crear" class="btn btn-primary"><i class="fa fa-plus"></i> Registrar Actividad</a>
            </div>
            <div class="box-body">
                <div class="timeline">
                    <!-- timeline time label -->
                    <span class="timeline-label">
                        <span class="badge badge-primary-light badge-pill">15 Abril 2024</span>
                    </span>
                    <!-- /.timeline-label -->
                    <!-- timeline item -->
                    <div class="timeline-item">
                        <div class="timeline-point timeline-point-success">
                            <i class="fa fa-phone"></i>
                        </div>
                        <div class="timeline-event">
                            <div class="timeline-heading">
                                <h4 class="timeline-title"><a href="#">Llamada con cliente</a></h4>
                                <span class="timeline-time"><i class="fa fa-clock-o"></i> 10:30 AM</span>
                            </div>
                            <div class="timeline-body">
                                Conversaci&oacute;n telef&oacute;nica con Ana Mart&iacute;nez (Tech Solutions LLC) sobre los requerimientos t&eacute;cnicos de la implementaci&oacute;n del ERP.
                            </div>
                        </div>
                    </div>
                    <!-- END timeline item -->

                    <!-- timeline item -->
                    <div class="timeline-item">
                        <div class="timeline-point timeline-point-info">
                            <i class="fa fa-envelope"></i>
                        </div>
                        <div class="timeline-event">
                            <div class="timeline-heading">
                                <h4 class="timeline-title"><a href="#">Correo enviado</a></h4>
                                <span class="timeline-time"><i class="fa fa-clock-o"></i> 02:15 PM</span>
                            </div>
                            <div class="timeline-body">
                                Se envi&oacute; la propuesta comercial actualizada a Acme Corporation.
                            </div>
                        </div>
                    </div>
                    <!-- END timeline item -->

                    <!-- timeline time label -->
                    <span class="timeline-label">
                        <span class="badge badge-info-light badge-pill">14 Abril 2024</span>
                    </span>
                    <!-- /.timeline-label -->

                    <!-- timeline item -->
                    <div class="timeline-item">
                        <div class="timeline-point timeline-point-warning">
                            <i class="fa fa-users"></i>
                        </div>
                        <div class="timeline-event">
                            <div class="timeline-heading">
                                <h4 class="timeline-title"><a href="#">Reuni&oacute;n presencial</a></h4>
                                <span class="timeline-time"><i class="fa fa-clock-o"></i> 09:00 AM</span>
                            </div>
                            <div class="timeline-body">
                                Presentaci&oacute;n del portafolio de servicios en las oficinas de Global Enterprises.
                            </div>
                        </div>
                    </div>
                    <!-- END timeline item -->
                </div>
            </div>
        </div>
    </div>
</div>




