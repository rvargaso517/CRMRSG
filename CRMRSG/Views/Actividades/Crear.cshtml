@{
    ViewBag.Title = "Registrar Actividad";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Registrar Actividad</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item"><a href="~/Actividades">Actividades</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Crear</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-6 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">Detalles de la Actividad</h4>
            </div>
            <form class="form">
                <div class="box-body">
                    <div class="form-group">
                        <label class="form-label">Tipo de Actividad</label>
                        <select class="form-select">
                            <option>Llamada Telefónica</option>
                            <option>Reunión Presencial</option>
                            <option>Reunión Virtual</option>
                            <option>Correo Electrónico</option>
                            <option>Demostración Técnica</option>
                        </select>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Fecha</label>
                                <input type="date" class="form-control" value="2024-04-15">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Hora</label>
                                <input type="time" class="form-control" value="10:00">
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Relacionado con</label>
                        <select class="form-select">
                            <option>Ninguno</option>
                            <optgroup label="Clientes">
                                <option>Acme Corporation</option>
                                <option>Tech Solutions</option>
                            </optgroup>
                            <optgroup label="Oportunidades">
                                <option>Venta Licencias Q3</option>
                                <option>Implementación ERP</option>
                            </optgroup>
                        </select>
                    </div>
                    <div class="form-group">
                        <label class="form-label">Descripción</label>
                        <textarea rows="4" class="form-control" placeholder="Resumen de lo que ocurrió en la actividad..."></textarea>
                    </div>
                </div>
                <div class="box-footer text-end">
                    <a href="~/Actividades" class="btn btn-warning me-1">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Registrar</button>
                </div>
            </form>
        </div>
    </div>
</div>
