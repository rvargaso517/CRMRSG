@{
    ViewBag.Title = "Registrar Actividad";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clientes = (List<CRMRSG.EntityFramework.cliente>)ViewBag.Clientes;
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Registrar Actividad</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item"><a href="~/Actividades">Actividades</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Crear</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-lg-8 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">Detalles de la Actividad</h4>
            </div>

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-20" role="alert">
                    <i class="ti-alert me-10"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @using (Html.BeginForm("Crear", "Actividades", FormMethod.Post, new { @class = "form" }))
            {
                @Html.AntiForgeryToken()

                <div class="box-body">
                    <div class="form-group mb-3">
                        <label class="form-label">Tipo de Actividad</label>
                        <select name="tipo_actividad" class="form-select" required>
                            <option value="Llamada Telefónica">📞 Llamada Telefónica</option>
                            <option value="Reunión Presencial">👥 Reunión Presencial</option>
                            <option value="Reunión Virtual">💻 Reunión Virtual</option>
                            <option value="Correo Electrónico">✉️ Correo Electrónico</option>
                            <option value="Demostración Técnica">🛠️ Demostración Técnica</option>
                        </select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Fecha</label>
                            <input type="date" name="fecha" class="form-control" value="@DateTime.Today.ToString("yyyy-MM-dd")" required />
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Hora</label>
                            <input type="time" name="hora" class="form-control" value="09:00" required />
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Relacionado con Cliente / Empresa</label>
                        <select name="id_cliente" class="form-select">
                            <option value="">-- Ninguno / Particular --</option>
                            @foreach (var c in clientes)
                            {
                                <option value="@c.id_cliente">@c.empresa (@c.nombre)</option>
                            }
                        </select>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Descripción o Minuta de Actividad</label>
                        <textarea name="descripcion" rows="5" class="form-control" placeholder="Describa brevemente lo acordado en la llamada, reunión o correo..." required></textarea>
                    </div>
                </div>

                <div class="box-footer text-end">
                    <a href="~/Actividades" class="btn btn-secondary me-1">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Registrar Actividad</button>
                </div>
            }
        </div>
    </div>
</div>
