@{
    ViewBag.Title = "Nueva Oportunidad";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var clientes = ViewBag.Clientes as IEnumerable<CRMRSG.EntityFramework.cliente> ?? new List<CRMRSG.EntityFramework.cliente>();
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Nueva Oportunidad</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item"><a href="~/Oportunidades">Oportunidades</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Crear</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">Detalles de la Oportunidad</h4>
            </div>
            @using (Html.BeginForm("Crear", "Oportunidades", FormMethod.Post, new { @class = "form" }))
            {
                @Html.AntiForgeryToken()

                <div class="box-body">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="form-group mb-3">
                        <label class="form-label">Nombre de la Oportunidad</label>
                        <input type="text" name="nombre" class="form-control" placeholder="Ej: Venta de Licencias Q3" required />
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Cliente Asociado</label>
                            <select name="id_cliente" class="form-select" required>
                                <option value="">Seleccione un cliente...</option>
                                @foreach (var client in clientes)
                                {
                                    <option value="@client.id_cliente">@client.nombre (@client.correo)</option>
                                }
                            </select>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Valor Estimado ($)</label>
                            <input type="number" step="0.01" name="valor_estimado" class="form-control" placeholder="0.00" required />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Etapa de Venta</label>
                            <select name="etapa" class="form-select" required>
                                <option value="Prospección">Prospección</option>
                                <option value="Calificación">Calificación</option>
                                <option value="Propuesta">Propuesta</option>
                                <option value="Negociación">Negociación</option>
                                <option value="Cerrada Ganada">Cerrada Ganada</option>
                                <option value="Cerrada Perdida">Cerrada Perdida</option>
                            </select>
                        </div>
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Fecha de Cierre Estimada</label>
                            <input type="date" name="fechaClose" class="form-control" required />
                        </div>
                    </div>

                    <div class="form-group mb-3">
                        <label class="form-label">Descripción</label>
                        <textarea rows="4" name="descripcion" class="form-control" placeholder="Detalles adicionales sobre la oportunidad..."></textarea>
                    </div>
                </div>

                <div class="box-footer text-end">
                    <a href="~/Oportunidades" class="btn btn-warning me-1">Cancelar</a>
                    <button type="submit" class="btn btn-primary">Guardar Oportunidad</button>
                </div>
            }
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            $('form').on('submit', function (e) {
                var etapa = $('select[name="etapa"]').val();
                if (etapa === 'Cerrada Perdida') {
                    var desc = $('textarea[name="descripcion"]').val();
                    if (!desc || !desc.includes('[Motivo Pérdida:')) {
                        var razon = prompt("Es obligatorio indicar la razón de la pérdida o cancelación de esta oportunidad:");
                        if (!razon || razon.trim() === '') {
                            alert("Debe especificar una razón para guardar la oportunidad como perdida.");
                            e.preventDefault();
                            return false;
                        }
                        $('textarea[name="descripcion"]').val((desc ? desc + "\n" : "") + "[Motivo Pérdida: " + razon + "]");
                    }
                }
            });
        });
    </script>
}
