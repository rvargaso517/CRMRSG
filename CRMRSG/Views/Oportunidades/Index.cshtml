                                <th>Nombre</th>
                                <th>Cliente</th>
                                <th>Valor Est.</th>
                                <th>Etapa</th>
                                <th>Probabilidad</th>
                                <th>Cierre Est.</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td><a href="#" class="fw-bold">Renovación de Licencias</a></td>
                                <td>Acme Corporation</td>
                                <td>$15,000</td>
                                <td><span class="badge badge-primary-light">Propuesta Enviada</span></td>
                                <td>
                                    <div class="progress progress-sm mb-0">
                                        <div class="progress-bar bg-primary" role="progressbar" style="width: 70%" aria-valuenow="70" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small>70%</small>
                                </td>
                                <td>15 May 2024</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-info-light"><i class="fa fa-pencil"></i></a>
