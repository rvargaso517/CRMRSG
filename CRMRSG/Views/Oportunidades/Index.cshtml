                                <td><span class="badge badge-warning-light">Negociación</span></td>
                                <td>
                                    <div class="progress progress-sm mb-0">
                                        <div class="progress-bar bg-warning" role="progressbar" style="width: 50%" aria-valuenow="50" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small>50%</small>
                                </td>
                                <td>30 Jun 2024</td>
                                <td>
                                    <a href="#" class="btn btn-sm btn-info-light"><i class="fa fa-pencil"></i></a>
                                </td>
                            </tr>
                            <tr>
                                <td><a href="#" class="fw-bold">Soporte Técnico Anual</a></td>
                                <td>Global Enterprises</td>
                                <td>$8,500</td>
                                <td><span class="badge badge-success-light">Ganada</span></td>
                                <td>
                                    <div class="progress progress-sm mb-0">
                                        <div class="progress-bar bg-success" role="progressbar" style="width: 100%" aria-valuenow="100" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div>
                                    <small>100%</small>
                                </td>
