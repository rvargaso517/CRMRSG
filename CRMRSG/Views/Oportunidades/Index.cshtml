@model IEnumerable<CRMRSG.EntityFramework.oportunidade>

@{
    ViewBag.Title = "Oportunidades";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Oportunidades</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item active" aria-current="page">Listado de Oportunidades</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Todas las Oportunidades</h3>
                <a href="~/Oportunidades/Crear" class="btn btn-primary"><i class="fa fa-plus"></i> Nueva Oportunidad</a>
            </div>
            <div class="box-body">
                @if (TempData["MensajeExito"] != null)
                {
                    <div class="alert alert-success alert-dismissible fade show mb-20" role="alert">
                        <i class="ti-check me-10"></i> @TempData["MensajeExito"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Nombre</th>
                                <th>Cliente</th>
                                <th>Valor Est.</th>
                                <th>Etapa</th>
                                <th>Probabilidad</th>
                                <th>Cierre Est.</th>
                                <th>Responsable</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted py-30">
                                        <i class="ti-info-alt fs-30 d-block mb-10"></i>
                                        No hay oportunidades registradas todavía.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                foreach (var item in Model)
                                {
                                    string badgeClass = "badge-primary-light";
                                    string progressBg = "bg-primary";
                                    string etapaLow = (item.etapa ?? "").ToLower();

                                    if (etapaLow.Contains("ganada"))
                                    {
                                        badgeClass = "badge-success-light";
                                        progressBg = "bg-success";
                                    }
                                    else if (etapaLow.Contains("perdida"))
                                    {
                                        badgeClass = "badge-danger-light";
                                        progressBg = "bg-danger";
                                    }
                                    else if (etapaLow.Contains("negociación") || etapaLow.Contains("negociacion"))
                                    {
                                        badgeClass = "badge-warning-light";
                                        progressBg = "bg-warning";
                                    }
                                    else if (etapaLow.Contains("propuesta"))
                                    {
                                        badgeClass = "badge-info-light";
                                        progressBg = "bg-info";
                                    }

                                    <tr id="row-op-@item.id_oportunidad">
                                        <td>
                                            <a href="~/Oportunidades/Detalle/@item.id_oportunidad" class="fw-bold text-primary">@item.nombre</a>
                                        </td>
                                        <td>
                                            @(item.cliente != null ? item.cliente.nombre : "Sin cliente")
                                        </td>
                                        <td class="fw-bold">
                                            @(item.valor_estimado.HasValue ? item.valor_estimado.Value.ToString("C") : "$0.00")
                                        </td>
                                        <td>
                                            <span class="badge @badgeClass">@item.etapa</span>
                                        </td>
                                        <td style="min-width: 120px;">
                                            <div class="d-flex align-items-center justify-content-between">
                                                <div class="progress progress-sm mb-0 flex-grow-1 me-10">
                                                    <div class="progress-bar @progressBg" role="progressbar" style="width: @(item.probabilidad ?? 50)%" aria-valuenow="@(item.probabilidad ?? 50)" aria-valuemin="0" aria-valuemax="100"></div>
                                                </div>
                                                <small class="fw-bold">@(item.probabilidad ?? 50)%</small>
                                            </div>
                                        </td>
                                        <td>
                                            @(item.fecha_creacion.HasValue ? item.fecha_creacion.Value.ToString("dd MMM yyyy") : "N/A")
                                        </td>
                                        <td>
                                            <span class="text-fade">@(item.usuario != null ? item.usuario.nombre : "CRM System")</span>
                                        </td>
                                        <td>
                                            <a href="~/Oportunidades/Detalle/@item.id_oportunidad" class="btn btn-sm btn-primary-light" title="Detalle"><i class="fa fa-eye"></i></a>
                                            <a href="~/Oportunidades/Editar/@item.id_oportunidad" class="btn btn-sm btn-info-light" title="Editar"><i class="fa fa-pencil"></i></a>
                                            @if (!etapaLow.Contains("ganada") && !etapaLow.Contains("perdida"))
                                            {
                                                <button onclick="cambiarEtapa(@item.id_oportunidad, 'Cerrada Ganada')" class="btn btn-sm btn-success-light" title="Marcar Ganada / Completada"><i class="fa fa-check"></i></button>
                                                <button onclick="cambiarEtapa(@item.id_oportunidad, 'Cerrada Perdida')" class="btn btn-sm btn-warning-light" title="Marcar Perdida / Cancelada"><i class="fa fa-times"></i></button>
                                            }
                                            <button onclick="eliminarOportunidad(@item.id_oportunidad, '@item.nombre')" class="btn btn-sm btn-danger-light" title="Eliminar"><i class="fa fa-trash"></i></button>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        function cambiarEtapa(id, etapa) {
            var actionName = etapa === 'Cerrada Ganada' ? 'completar/ganar' : 'cancelar/perder';
            var razon = '';
            if (etapa === 'Cerrada Perdida') {
                razon = prompt("Es obligatorio ingresar la razón de pérdida o cancelación para esta oportunidad:");
                if (razon === null) {
                    return; // Clic en Cancelar
                }
                if (razon.trim() === '') {
                    alert("Debe especificar una razón válida.");
                    return;
                }
            } else {
                if (!confirm("¿Está seguro de que desea " + actionName + " esta oportunidad?")) {
                    return;
                }
            }

            $.ajax({
                url: '@Url.Action("CambiarEtapa", "Oportunidades")',
                type: 'POST',
                data: { id: id, etapa: etapa, razon: razon },
                success: function (res) {
                    if (res.success) {
                        location.reload();
                    } else {
                        alert("Error al actualizar la oportunidad: " + res.message);
                    }
                },
                error: function () {
                    alert("Error de red al intentar actualizar.");
                }
            });
        }

        function eliminarOportunidad(id, nombre) {
            if (confirm("¿Está seguro de que desea eliminar la oportunidad '" + nombre + "'?")) {
                $.ajax({
                    url: '@Url.Action("Eliminar", "Oportunidades")',
                    type: 'POST',
                    data: { id: id },
                    success: function (res) {
                        if (res.success) {
                            $('#row-op-' + id).fadeOut(300, function () {
                                $(this).remove();
                            });
                        } else {
                            alert("Error al eliminar: " + res.message);
                        }
                    },
                    error: function () {
                        alert("Error de red al intentar eliminar.");
                    }
                });
            }
        }
    </script>
}
