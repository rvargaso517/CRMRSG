@model IEnumerable<CRMRSG.EntityFramework.cliente>
@{
    ViewBag.Title = "Clientes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Clientes</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item active" aria-current="page">Listado de Clientes</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Todos los Clientes</h3>
                <a href="~/Clientes/Crear" class="btn btn-primary"><i class="fa fa-plus"></i> Nuevo Cliente</a>
            </div>
            <div class="box-body">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Empresa</th>
                                <th>Contacto Principal</th>
                                <th>Email</th>
                                <th>Tel&eacute;fono</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Model != null && Model.Any())
                            {
                                foreach (var item in Model)
                                {
                                    <tr>
                                        <td>#C-@item.id_cliente.ToString("D3")</td>
                                        <td>
                                            <!-- PASO 3: Redirección profesional usando el Helper de ASP.NET a la vista Detalle -->
                                            <a href="@Url.Action("Detalle", "Clientes", new { id = item.id_cliente })" class="fw-bold text-info" title="Ver ficha y contactos">
                                                @item.empresa
                                            </a>
                                        </td>
                                        <td>@item.nombre</td>
                                        <td>@item.correo</td>
                                        <td>@item.telefono</td>
                                        <td>
                                            @if (item.estado == "Activo" || item.estado == "1")
                                            {
                                                <span class="badge badge-success-light">Activo</span>
                                            }
                                            else if (item.estado != null && (item.estado.Contains("Negociac") || item.estado == "En Negociaci&oacute;n"))
                                            {
                                                <span class="badge badge-warning-light">En Negociaci&oacute;n</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger-light">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <a href="@Url.Action("Editar", "Clientes", new { id = item.id_cliente })" class="btn btn-sm btn-info-light" title="Editar">
                                                <i class="fa fa-pencil"></i>
                                            </a>
                                            <button type="button" class="btn btn-sm btn-danger-light" onclick="confirmarEliminar(@item.id_cliente, '@item.empresa')" title="Eliminar">
                                                <i class="fa fa-trash"></i>
                                            </button>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center text-muted">No hay clientes registrados en la base de datos.</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script>
    function confirmarEliminar(id, empresa) {
        var urlEliminar = '@Url.Action("Eliminar", "Clientes")';

        // Mensaje limpio sin caracteres raros para la confirmación
        if (confirm("Sistema CRM-RSG: ¿Está seguro de que desea eliminar permanentemente a la empresa '" + empresa + "'?")) {
            $.ajax({
                url: urlEliminar,
                type: 'POST',
                data: { id: id },
                success: function (response) {
                    if (response.success) {
                        alert(response.message);
                        location.reload();
                    } else {
                        alert(response.message);
                    }
                },
                error: function () {
                    alert("Ocurrió un error en el servidor al intentar eliminar.");
                }
            });
        }
    }
</script>