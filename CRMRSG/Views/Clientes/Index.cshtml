@model List<CRMRSG.EntityFramework.clientes>

@{
    ViewBag.Title = "Clientes";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Clientes</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item">
                            <a href="~/Dashboard">
                                <i class="mdi mdi-home-outline"></i>
                            </a>
                        </li>
                        <li class="breadcrumb-item active" aria-current="page">
                            Listado de Clientes
                        </li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">

            <div class="box-header with-border d-flex justify-content-between align-items-center">
                <h3 class="box-title">Todos los Clientes</h3>

                <a href="~/Clientes/Crear" class="btn btn-primary">
                    <i class="fa fa-plus"></i> Nuevo Cliente
                </a>
            </div>

            <div class="box-body">

                <div class="table-responsive">

                    <table class="table table-hover mb-0">

                        <thead>
                            <tr>
                                <th>ID</th>
                                <th>Empresa</th>
                                <th>Contacto Principal</th>
                                <th>Email</th>
                                <th>Teléfono</th>
                                <th>Estado</th>
                                <th>Acciones</th>
                            </tr>
                        </thead>

                        <tbody>

                            @if (Model != null && Model.Count > 0)
                            {
                                foreach (var item in Model)
                                {
                                    <tr>

                                        <td>
                                            #C-@item.id_cliente
                                        </td>

                                        <td>
                                            <a href="~/Clientes/Detalle/@item.id_cliente"
                                               class="fw-bold">
                                                @item.empresa
                                            </a>
                                        </td>

                                        <td>
                                            @item.nombre
                                        </td>

                                        <td>
                                            @item.correo
                                        </td>

                                        <td>
                                            @item.telefono
                                        </td>

                                        <td>

                                            @if (item.estado == "Activo")
                                            {
                                                <span class="badge badge-success-light">
                                                    @item.estado
                                                </span>
                                            }
                                            else if (item.estado == "En Negociación")
                                            {
                                                <span class="badge badge-warning-light">
                                                    @item.estado
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-danger-light">
                                                    @item.estado
                                                </span>
                                            }

                                        </td>

                                        <td>

                                            <a href="~/Clientes/Editar/@item.id_cliente"
                                               class="btn btn-sm btn-info-light">
                                                <i class="fa fa-pencil"></i>
                                            </a>

                                            <a href="~/Clientes/Detalle/@item.id_cliente"
                                               class="btn btn-sm btn-primary-light">
                                                <i class="fa fa-eye"></i>
                                            </a>

                                            <a href="~/Clientes/Eliminar/@item.id_cliente"
                                               class="btn btn-sm btn-danger-light"
                                               onclick="return confirm('¿Desea eliminar este cliente?');">
                                                <i class="fa fa-trash"></i>
                                            </a>

                                        </td>

                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center">
                                        No hay clientes registrados.
                                    </td>
                                </tr>
                            }

                        </tbody>

                    </table>

                </div>

            </div>

        </div>
    </div>
</div>