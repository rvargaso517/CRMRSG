@model CRMRSG.EntityFramework.cliente
@{
    ViewBag.Title = "Nuevo Cliente";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <div class="d-flex align-items-center">
        <div class="me-auto">
            <h4 class="page-title">Nuevo Cliente</h4>
            <div class="d-inline-block align-items-center">
                <nav>
                    <ol class="breadcrumb">
                        <li class="breadcrumb-item"><a href="~/Dashboard"><i class="mdi mdi-home-outline"></i></a></li>
                        <li class="breadcrumb-item"><a href="~/Clientes">Clientes</a></li>
                        <li class="breadcrumb-item active" aria-current="page">Crear</li>
                    </ol>
                </nav>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="box">
            <div class="box-header with-border">
                <h3 class="box-title">Informaci&oacute;n del Cliente</h3>
            </div>

            @using (Html.BeginForm("Crear", "Clientes", FormMethod.Post, new { @class = "form" }))
            {
                @Html.AntiForgeryToken()

                <div class="box-body">
                    <h4 class="box-title text-info mb-0"><i class="ti-user me-15"></i> Perfil Principal</h4>
                    <hr class="my-15">
                    
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Nombre de la Empresa</label>
                                @Html.TextBoxFor(m => m.empresa, new { @class = "form-control", placeholder = "Ej: Acme Corp", required = "required" })
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Estado</label>
                                <select name="estado" class="form-control">
                                    <option value="Activo">Activo</option>
                                    <option value="En Negociaci&oacute;n">En Negociaci&oacute;n</option>
                                    <option value="Inactivo">Inactivo</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <h4 class="box-title text-info mb-0 mt-20"><i class="ti-briefcase me-15"></i> Detalles del Trabajo (Visual)</h4>
                    <hr class="my-15">
                    <div class="row">
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">Tipo de Trabajo (Eventos/Tareas)</label>
                                <input type="text" class="form-control" placeholder="Ej: Implementaci&oacute;n de ERP">
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">Ganancia Estimada</label>
                                <div class="input-group">
                                    <span class="input-group-text">$</span>
                                    <input type="number" class="form-control" placeholder="0.00">
                                </div>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="form-group">
                                <label class="form-label">Periodo de Tiempo</label>
                                <input type="text" class="form-control" placeholder="Ej: 3 meses">
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Descripci&oacute;n</label>
                                <textarea class="form-control" rows="2" placeholder="Detalles del trabajo..."></textarea>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label class="form-label">Logo de la Empresa</label>
                                <input type="file" class="form-control">
                            </div>
                        </div>
                    </div>

                    <h4 class="box-title text-info mb-0 mt-20"><i class="ti-user me-15"></i> Contactos M&uacute;ltiples (Visual)</h4>
                    <hr class="my-15">
                    <div id="contactos-container">
                        <div class="row mb-10">
                            <div class="col-md-3"><label class="form-label">Nombres</label>@Html.TextBoxFor(m => m.nombre, new { @class = "form-control", placeholder = "Ej: Juan" })</div>
                            <div class="col-md-2"><label class="form-label">Apellidos</label><input type="text" class="form-control" placeholder="Ej: P&eacute;rez" /></div>
                            <div class="col-md-2"><label class="form-label">Tel&eacute;fono</label>@Html.TextBoxFor(m => m.telefono, new { @class = "form-control", placeholder = "+1 234 567" })</div>
                            <div class="col-md-3"><label class="form-label">Correo</label>@Html.TextBoxFor(m => m.correo, new { @class = "form-control", placeholder = "email@empresa.com", type = "email" })</div>
                            <div class="col-md-2"><label class="form-label">Tipo Contacto</label>
                                <select class="form-control">
                                    <option>Contacto principal</option>
                                    <option>Contacto inicial</option>
                                    <option>Contacto de tarea</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <button type="button" class="btn btn-sm btn-outline-secondary mt-10" onclick="alert('Funcionalidad visual de agregar m&aacute;s contactos en demo')">+ A&ntilde;adir otro contacto</button>

                    <h4 class="box-title text-info mb-0 mt-20"><i class="ti-location-pin me-15"></i> Ubicaci&oacute;n</h4>
                    <hr class="my-15">

                    <div class="row">
                        <div class="col-12">
                            <div class="form-group">
                                <label class="form-label">Direcci&oacute;n</label>
                                @Html.TextAreaFor(m => m.direccion, new { @class = "form-control", rows = "3", placeholder = "Calle, Numero, Ciudad" })
                            </div>
                        </div>
                    </div>
                </div>

                <div class="box-footer text-end">
                    <a href="@Url.Action("Index", "Clientes")" class="btn btn-warning me-1">
                        <i class="ti-trash"></i> Cancelar
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="ti-save-alt"></i> Guardar Cambios
                    </button>
                </div>
            }
        </div>
    </div>
</div>





