@model CRMRSG.EntityFramework.usuario

@{
    ViewBag.Title = "Mi Perfil";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="content-header">
    <h4 class="page-title">Configuración de Cuenta</h4>
</div>

<div class="row">
    <!-- Tarjeta Visual del Perfil -->
    <div class="col-lg-4 col-12">
        <div class="box bg-neutral text-center py-4 px-3">
            <div class="mb-20">
                <i class="ti-user text-primary bg-primary-light rounded-circle p-20 fs-40"></i>
            </div>
            <h3 class="fw-bold text-dark mb-5">@Model.nombre @Model.apellido</h3>
            <p class="text-fade">@Model.correo</p>
            <span class="badge badge-lg badge-primary-light">
                @(Model.role != null ? Model.role.nombre : "Colaborador CRM")
            </span>
        </div>
    </div>

    <!-- Formulario de Edición Directa -->
    <div class="col-lg-8 col-12">
        <div class="box">
            <div class="box-header with-border">
                <h4 class="box-title">Información Personal</h4>
            </div>

            @if (TempData["MensajeExito"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show m-20" role="alert">
                    <i class="ti-check me-10"></i> @TempData["MensajeExito"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @if (TempData["MensajeError"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show m-20" role="alert">
                    <i class="ti-alert me-10"></i> @TempData["MensajeError"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            }

            @using (Html.BeginForm("Actualizar", "Perfil", FormMethod.Post, new { @class = "form" }))
            {
                @Html.AntiForgeryToken()
                @Html.HiddenFor(m => m.id_usuario)

                <div class="box-body">
                    @Html.ValidationSummary(true, "", new { @class = "text-danger" })

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Nombre</label>
                            @Html.TextBoxFor(m => m.nombre, new { @class = "form-control", required = "required" })
                            @Html.ValidationMessageFor(m => m.nombre, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Apellido</label>
                            @Html.TextBoxFor(m => m.apellido, new { @class = "form-control" })
                            @Html.ValidationMessageFor(m => m.apellido, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Correo Electrónico</label>
                            @Html.TextBoxFor(m => m.correo, new { @class = "form-control", type = "email", required = "required" })
                            @Html.ValidationMessageFor(m => m.correo, "", new { @class = "text-danger" })
                        </div>

                        <div class="col-md-6 form-group mb-3">
                            <label class="form-label">Teléfono</label>
                            @Html.TextBoxFor(m => m.telefono, new { @class = "form-control", placeholder = "Ej: +506 8888-8888" })
                            @Html.ValidationMessageFor(m => m.telefono, "", new { @class = "text-danger" })
                        </div>
                    </div>

                    <hr />

                    <div class="form-group mb-3">
                        <label class="form-label">Nueva Contraseña (Dejar en blanco si no desea cambiarla)</label>
                        <input type="password" name="nuevaPassword" class="form-control" placeholder="Mínimo 8 caracteres" />
                    </div>
                </div>

                <div class="box-footer text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="ti-save-alt me-5"></i> Guardar Cambios
                    </button>
                </div>
            }
        </div>
    </div>
</div>