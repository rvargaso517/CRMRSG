@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Alfa Admin - Registrarse</title>
  
    <!-- Vendors Style-->
    <link rel="stylesheet" href="~/Content/css/vendors_css.css">
      
    <!-- Style-->  
    <link rel="stylesheet" href="~/Content/css/style.css">
    <link rel="stylesheet" href="~/Content/css/skin_color.css">	

</head>
    
<body class="hold-transition theme-primary bg-img" style="background-image: url(@Url.Content("~/Content/images/auth-bg/bg-16.jpg"))">
    
    <div class="container h-p100">
        <div class="row align-items-center justify-content-md-center h-p100">	
            
            <div class="col-12">
                <div class="row justify-content-center g-0">
                    <div class="col-lg-5 col-md-5 col-12">
                        <div class="bg-white rounded10 shadow-lg">
                            <div class="content-top-agile p-20 pb-0">
                                <h2 class="text-primary fw-600">Crear una Cuenta</h2>
                                <p class="mb-0 text-fade">Únase a nuestro sistema CRM.</p>							
                            </div>
                            <div class="p-40">
                                <form action="~/Home/Login" method="post">
                                    <div class="form-group">
                                        <div class="input-group mb-3">
                                            <span class="input-group-text bg-transparent"><i class="text-fade ti-user"></i></span>
                                            <input type="text" class="form-control ps-15 bg-transparent" placeholder="Nombre Completo">
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <div class="input-group mb-3">
                                            <span class="input-group-text bg-transparent"><i class="text-fade ti-email"></i></span>
                                            <input type="email" class="form-control ps-15 bg-transparent" placeholder="Correo Electrónico">
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <div class="input-group mb-3">
                                            <span class="input-group-text bg-transparent"><i class="text-fade ti-lock"></i></span>
                                            <input type="password" class="form-control ps-15 bg-transparent" placeholder="Contraseña">
                                        </div>
                                    </div>
                                    <div class="form-group">
                                        <div class="input-group mb-3">
                                            <span class="input-group-text bg-transparent"><i class="text-fade ti-lock"></i></span>
                                            <input type="password" class="form-control ps-15 bg-transparent" placeholder="Confirmar Contraseña">
                                        </div>
                                    </div>
                                      <div class="row">
                                        <div class="col-12">
                                          <div class="checkbox">
                                            <input type="checkbox" id="basic_checkbox_1" >
                                            <label for="basic_checkbox_1">Acepto los Términos y Condiciones</label>
                                          </div>
                                        </div>
                                        <div class="col-12 text-center">
                                          <button type="submit" class="btn btn-primary w-p100 mt-10">REGISTRARSE</button>
                                        </div>
                                      </div>
                                </form>	
                                <div class="text-center">
                                    <p class="mt-15 mb-0 text-fade">¿Ya tiene una cuenta? <a href="~/Home/Login" class="text-primary ms-5">Iniciar Sesión</a></p>
                                </div>
                            </div>						
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Vendor JS -->
    <script src="~/Content/js/vendors.min.js"></script>
    <script src="~/Content/assets/icons/feather-icons/feather.min.js"></script>	

</body>
</html>
